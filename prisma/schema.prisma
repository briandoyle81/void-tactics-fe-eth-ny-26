generator client {
  provider = "prisma-client-js"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ── Users ──────────────────────────────────────────────────────────────────────

model User {
  id                 String    @id // Google OAuth sub (user.id from NextAuth)
  email              String    @unique
  username           String?
  creditBalance      Int       @default(0)
  purchasedShipCount Int       @default(0)
  lobbiesCreatedCount  Int      @default(0) // total lobby creations; first freeGamesPerAddress are free
  kickCount            Int      @default(0) // cumulative times timed out/kicked from lobbies
  kickTimeoutUntil     DateTime? // locked out of creating/joining lobbies until this time
  tutorialCompleted    Boolean  @default(false)
  tutorialPath         String?  // "win" | "loss" — which branch the player finished
  createdAt            DateTime @default(now())

  ships           Ship[]
  lobbiesCreated  Lobby[]       @relation("LobbyCreator")
  lobbiesJoined   Lobby[]       @relation("LobbyJoiner")
  lobbiesReserved Lobby[]       @relation("LobbyReservedJoiner")
  gamesAsPlayer1  Game[]        @relation("GamePlayer1")
  gamesAsPlayer2  Game[]        @relation("GamePlayer2")
  fleets          Fleet[]
  stats           PlayerStats?
}

// ── Ships ──────────────────────────────────────────────────────────────────────

model Ship {
  id             Int       @id @default(autoincrement())
  ownerId        String
  owner          User      @relation(fields: [ownerId], references: [id])
  name           String    @default("Ship")
  // equipment: { mainWeapon: 0-3, armor: 0-3, shields: 0-3, special: 0-3 }
  equipment      Json
  // traits: { serialNumber, colors: { h1,s1,l1,h2,s2,l2 }, variant, accuracy, hull, speed }
  traits         Json
  cost           Int       @default(0)
  costsVersion   Int       @default(0)
  isFree         Boolean   @default(false)
  modifiedCount  Int       @default(0)
  shiny          Boolean   @default(false)
  constructed    Boolean   @default(false)
  inFleet        Boolean   @default(false)
  destroyed      Boolean   @default(false)
  shipsDestroyed Int       @default(0)
  destroyedAt    DateTime?
  createdAt      DateTime  @default(now())

  @@index([ownerId])
  @@index([ownerId, destroyed])
}

// ── Fleets ─────────────────────────────────────────────────────────────────────
// One fleet per player per lobby. Query: fleet where lobbyId=X and ownerId=Y.

model Fleet {
  id                Int      @id @default(autoincrement())
  ownerId           String
  owner             User     @relation(fields: [ownerId], references: [id])
  lobbyId           Int
  lobby             Lobby    @relation(fields: [lobbyId], references: [id])
  // Ship IDs in this fleet (references Ship.id)
  shipIds           Int[]
  totalCost         Int      @default(0)
  isComplete        Boolean  @default(false)
  // Starting grid positions: [{ row, col }] indexed to match shipIds
  startingPositions Json?
  createdAt         DateTime @default(now())

  @@index([lobbyId])
  @@index([lobbyId, ownerId])
}

// ── Lobbies ────────────────────────────────────────────────────────────────────

model Lobby {
  id                Int         @id @default(autoincrement())
  creatorId         String
  creator           User        @relation("LobbyCreator", fields: [creatorId], references: [id])
  joinerId          String?
  joiner            User?       @relation("LobbyJoiner", fields: [joinerId], references: [id])
  reservedJoinerId  String?     // pre-set joiner for private lobbies
  reservedJoiner    User?       @relation("LobbyReservedJoiner", fields: [reservedJoinerId], references: [id])
  mapId             Int?
  map               Map?        @relation(fields: [mapId], references: [id])
  status            LobbyStatus @default(OPEN)
  costLimit         Int         @default(0) // max total fleet cost
  turnTimeSeconds   Int         @default(120)
  maxScore          Int         @default(3)
  creatorGoesFirst  Boolean?
  createdAt         DateTime    @default(now())
  joinedAt          DateTime?
  joinerFleetSetAt  DateTime?   // when joiner submitted their fleet (for quitWithPenalty check)

  fleets            Fleet[]
  game              Game?

  @@index([creatorId])
  @@index([joinerId])
  @@index([status])
}

enum LobbyStatus {
  OPEN
  FLEET_SELECTION
  IN_GAME
  CANCELLED
  COMPLETED
}

// ── Games ──────────────────────────────────────────────────────────────────────

model Game {
  id           Int       @id @default(autoincrement())
  lobbyId      Int       @unique
  lobby        Lobby     @relation(fields: [lobbyId], references: [id])
  player1Id    String // creator
  player1      User      @relation("GamePlayer1", fields: [player1Id], references: [id])
  player2Id    String // joiner
  player2      User      @relation("GamePlayer2", fields: [player2Id], references: [id])
  // Full serialised GameDataView — served directly to the client
  state        Json
  initialState Json?     // GameDataView at game start — used for replay
  currentTurn  String // userId of the player whose turn it is
  currentRound Int       @default(1)
  phase        GamePhase @default(ACTIVE)
  winnerId     String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  turns        GameTurn[]

  @@index([player1Id])
  @@index([player2Id])
}

enum GamePhase {
  ACTIVE
  COMPLETED
  TIMED_OUT
  ABANDONED
}

model GameTurn {
  id          Int      @id @default(autoincrement())
  gameId      Int
  game        Game     @relation(fields: [gameId], references: [id])
  playerId    String
  round       Int
  // Array of actions submitted this turn: [{ type, shipId, targetRow, targetCol, ... }]
  actions     Json
  // Full GameDataView snapshot after this action — used for step-through replay
  snapshot    Json?
  submittedAt DateTime @default(now())

  @@index([gameId, round])
}

// ── Maps ───────────────────────────────────────────────────────────────────────

model Map {
  id           Int      @id @default(autoincrement())
  name         String
  gridWidth    Int      @default(17)
  gridHeight   Int      @default(11)
  // [{ row, col }]
  blockedTiles Json     @default("[]")
  // [{ row, col, points, onlyOnce }]
  scoringTiles Json     @default("[]")
  createdAt    DateTime @default(now())

  lobbies      Lobby[]
}

// ── System Config ──────────────────────────────────────────────────────────────
// Key/value store for admin-managed settings (e.g. ship cost tables).

model Config {
  key       String   @id
  value     Json
  updatedAt DateTime @updatedAt
}

// ── Player Stats ───────────────────────────────────────────────────────────────

model PlayerStats {
  userId     String @id
  user       User   @relation(fields: [userId], references: [id])
  wins       Int    @default(0)
  losses     Int    @default(0)
  draws      Int    @default(0)
  totalGames Int    @default(0)

  @@index([wins])
}
